<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="theme-color" content="#1A56DB">
<title>LoomiQ — Мерч для команди</title>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;700;900&family=Onest:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

:root {
  --white: #ffffff;
  --bg: #F2F2F2;
  --bg2: #EAEAEA;
  --black: #0D0D0D;
  --blue: #1A56DB;
  --blue-dark: #1340B0;
  --blue-light: #EEF4FF;
  --muted: #777;
  --border: #DEDEDE;
  --safe-top: max(20px, env(safe-area-inset-top));
  --safe-bottom: max(20px, env(safe-area-inset-bottom));
  --safe-left: max(16px, env(safe-area-inset-left));
  --safe-right: max(16px, env(safe-area-inset-right));
}

html {
  scroll-behavior: smooth;
  -webkit-text-size-adjust: 100%;
  -webkit-user-select: none;
  overflow-x: hidden;
}

body {
  background: var(--bg);
  color: var(--black);
  overflow-x: hidden;
  width: 100%;
  max-width: 100vw;
  font-family: 'Onest', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  overflow-x: hidden;
  -webkit-user-select: none;
  user-select: none;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes slideDown {
  from {
    opacity: 0;
    transform: translateY(-10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-up {
  animation: fadeUp 0.6s ease forwards;
}

.fade-up:nth-child(1) { animation-delay: 0.1s; }
.fade-up:nth-child(2) { animation-delay: 0.2s; }
.fade-up:nth-child(3) { animation-delay: 0.3s; }

/* ===== HEADER ===== */
header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1000;
  height: 56px;
  display: flex;
  align-items: center;
  padding: 0 var(--safe-left) 0 var(--safe-left);
  background: rgba(242, 242, 242, 0.98);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: background 0.3s;
  padding-top: var(--safe-top);
}

header.scrolled {
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.header-inner {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.logo {
  font-family: 'Unbounded', sans-serif;
  font-size: 18px;
  font-weight: 900;
  color: var(--black);
  text-decoration: none;
  letter-spacing: -0.02em;
  flex-shrink: 0;
}

.header-center {
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  flex-grow: 1;
  text-align: center;
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  font-family: 'Onest', sans-serif;
  font-weight: 700;
  border: none;
  cursor: pointer;
  text-decoration: none;
  border-radius: 6px;
  transition: all 0.2s;
  padding: 10px 16px;
  font-size: 12px;
  flex-shrink: 0;
  min-height: 40px;
  touch-action: manipulation;
}

.btn:active {
  transform: scale(0.98);
}

.btn-primary {
  background: var(--blue);
  color: #fff;
  box-shadow: 0 2px 8px rgba(26, 86, 219, 0.2);
}

.btn-primary:active {
  background: var(--blue-dark);
}

.btn-ghost {
  background: transparent;
  color: var(--black);
  border: 1.5px solid var(--border);
}

.btn-ghost:active {
  border-color: var(--black);
  background: rgba(0, 0, 0, 0.05);
}

/* ===== HERO ===== */
.hero {
  min-height: 100vh;
  min-height: 100svh;
  background: var(--bg);
  position: relative;
  overflow: hidden;
}

/* Photo: large background, right-aligned, full height */
.hero-bg-wrap {
  position: absolute;
  right: 0;
  top: 0;
  width: 88%;
  height: 100%;
  z-index: 0;
}

.hero-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: right center;
  display: block;
}

/* Gradient: full-width overlay, solid left → transparent right */
.hero-bg-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to right,
    #F2F2F2 0%,
    #F2F2F2 10%,
    rgba(242, 242, 242, 0.85) 28%,
    rgba(242, 242, 242, 0.38) 52%,
    rgba(242, 242, 242, 0.05) 75%,
    transparent 100%
  );
}

/* Vertical flex: title top, spacer (shows photo), desc+btn bottom */
.hero-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  padding: calc(56px + var(--safe-top) + 20px) 20px 0;
  box-sizing: border-box;
}

.hero-title-block {
  /* title at top */
}

.hero-title {
  font-family: 'Unbounded', sans-serif;
  font-size: clamp(32px, 8.5vw, 48px);
  font-weight: 900;
  line-height: 1.05;
  letter-spacing: -0.025em;
  color: var(--black);
  width: 86%;
}

.hero-title-accent {
  color: var(--blue);
  display: block;
  font-style: italic;
  margin-top: 4px;
}

/* Two spacers sandwich the desc — centers it between title and button */
.hero-spacer-top {
  flex: 0.6;
  min-height: 16px;
}

.hero-spacer-bottom {
  flex: 1;
  min-height: 16px;
}

.hero-desc {
  font-size: 15px;
  color: #333;
  line-height: 1.65;
  width: 70%;
  margin: 0;
  flex-shrink: 0;
}

.hero-cta {
  width: 100%;
  padding: 16px;
  font-size: 15px;
  font-weight: 700;
  border-radius: 14px;
  box-sizing: border-box;
  letter-spacing: 0.01em;
  margin-bottom: calc(24px + var(--safe-bottom, 20px));
  flex-shrink: 0;
}

/* ===== LOGOS SECTION ===== */
.logos-section {
  background: var(--white);
  padding: 24px var(--safe-left);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  overflow: hidden;
}

.logos-inner {
  display: flex;
  align-items: center;
  gap: 16px;
  overflow: auto;
  -webkit-overflow-scrolling: touch;
  scroll-behavior: smooth;
  scrollbar-width: none;
}

.logos-inner::-webkit-scrollbar {
  display: none;
}

.logos-label {
  font-size: 10px;
  font-weight: 600;
  color: #aaa;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  white-space: nowrap;
  flex-shrink: 0;
}

.marquee-item {
  padding: 0 12px;
  font-family: 'Unbounded', sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: #BBBBBB;
  letter-spacing: 0.08em;
  border-right: 1px solid var(--border);
  white-space: nowrap;
  flex-shrink: 0;
}

/* ===== STATS ===== */
.stats-section {
  padding: 32px var(--safe-left) 32px;
  background: var(--bg);
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

.stat-item {
  background: var(--white);
  padding: 24px 16px;
  text-align: center;
  border-radius: 12px;
  border: 1px solid var(--border);
  transition: background 0.25s;
}

.stat-item:active {
  background: var(--blue-light);
}

.stat-num {
  font-family: 'Unbounded', sans-serif;
  font-size: 32px;
  font-weight: 900;
  line-height: 1;
  margin-bottom: 8px;
  color: var(--black);
}

.stat-num span {
  color: var(--blue);
}

.stat-label {
  font-size: 13px;
  color: var(--muted);
}

/* ===== SECTION STYLES ===== */
.sec-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--blue);
  margin-bottom: 8px;
}

h2 {
  font-family: 'Unbounded', sans-serif;
  font-size: clamp(24px, 5vw, 36px);
  font-weight: 900;
  letter-spacing: -0.025em;
  line-height: 1.2;
  margin-bottom: 8px;
}

.sec-sub {
  font-size: 14px;
  color: var(--muted);
  margin-bottom: 24px;
  line-height: 1.6;
}

.section {
  padding: 40px var(--safe-left);
}

/* ===== HOW SECTION — premium white ===== */
.how-section {
  background: #fff;
  position: relative;
  overflow: hidden;
  padding: 40px 20px 0;
}

.how-section .sec-label {
  color: #2563FF;
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
}

.how-section .sec-label::before {
  content: '';
  width: 7px;
  height: 7px;
  background: #2563FF;
  border-radius: 50%;
  display: inline-block;
  flex-shrink: 0;
}

.how-section h2 {
  color: var(--black);
  font-size: clamp(22px, 6vw, 30px);
  margin-bottom: 6px;
}

.how-section .sec-sub {
  color: #666;
  font-size: 13px;
  line-height: 1.6;
  margin-bottom: 0;
}

/* Step cards list */
.steps-list {
  margin-top: 24px;
  display: flex;
  flex-direction: column;
}

.step-card {
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
  border: 1px solid rgba(0, 0, 0, 0.05);
  padding: 18px 0 18px 18px;
  display: flex;
  align-items: center;
  gap: 0;
  overflow: hidden;
  position: relative;
  transition: transform 0.2s;
}

.step-card:active {
  transform: scale(0.99);
}

.step-card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-right: 12px;
}

.step-badge {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: rgba(37, 99, 255, 0.08);
  color: #2563FF;
  font-family: 'Unbounded', sans-serif;
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  flex-shrink: 0;
}

.step-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--black);
  margin-bottom: 6px;
  line-height: 1.3;
}

.step-text {
  font-size: 12px;
  color: #888;
  line-height: 1.55;
}

.step-image {
  width: 130px;
  height: 110px;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 0 18px 18px 0;
}

.step-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

/* Dashed arrow connector between cards */
.step-arrow {
  display: flex;
  align-items: center;
  padding: 4px 0 4px 28px;
}

/* ===== CTA BLOCK (replacing old hook) ===== */
.steps-cta-wrap {
  padding: 28px 20px 40px;
  background: #fff;
}

.steps-cta-card {
  background: linear-gradient(135deg, #f0f5ff 0%, #f8f9ff 100%);
  border-radius: 20px;
  padding: 24px 20px;
  border: 1px solid rgba(37, 99, 255, 0.1);
}

.steps-cta-top {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}

.steps-cta-icon {
  width: 68px;
  height: 68px;
  border-radius: 50%;
  border: 3px solid #2563FF;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #fff;
  box-shadow: 0 4px 12px rgba(37,99,255,0.15);
}

.steps-cta-icon-inner {
  text-align: center;
  line-height: 1;
}

.steps-cta-num {
  font-family: 'Unbounded', sans-serif;
  font-size: 22px;
  font-weight: 900;
  color: #2563FF;
  display: block;
  line-height: 1.1;
}

.steps-cta-unit {
  font-size: 10px;
  color: #2563FF;
  font-weight: 600;
  letter-spacing: 0.05em;
}

.steps-cta-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: var(--black);
  line-height: 1.35;
}

.steps-cta-title em {
  color: #2563FF;
  font-style: normal;
}

.steps-cta-btn {
  width: 100%;
  padding: 16px;
  font-size: 15px;
  font-weight: 700;
  border-radius: 14px;
  background: #2563FF;
  color: #fff;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  text-decoration: none;
  font-family: 'Onest', sans-serif;
  letter-spacing: 0.01em;
  transition: background 0.2s;
}

.steps-cta-btn:active {
  background: #1d4ed8;
}

/* ===== CATALOG ===== */
/* ===== CATALOG — premium minimal ===== */
.catalog-section {
  background: #fff;
  padding: 40px 20px 40px;
}

.catalog-section .sec-label {
  color: #2563FF;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  margin-bottom: 8px;
}

.catalog-section h2 {
  font-size: clamp(26px, 7vw, 36px);
  margin-bottom: 6px;
}

.catalog-section .sec-sub {
  font-size: 13px;
  color: #777;
  margin-bottom: 24px;
}

.catalog-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.cat-card {
  background: #fff;
  border-radius: 18px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
  border: 1.5px solid #E8E8E8;
}

.cat-card:active {
  transform: scale(0.98);
  box-shadow: 0 6px 20px rgba(0,0,0,0.10);
}

.cat-photo {
  background: #F4F4F5;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 10px;
  box-sizing: border-box;
}

.cat-photo img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  object-position: center;
  display: block;
}

.cat-info {
  padding: 12px 12px 12px;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.cat-info-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.cat-name {
  font-family: 'Unbounded', sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: #0D0D0D;
  line-height: 1.3;
}

.cat-price {
  font-size: 11px;
  color: #888;
  font-weight: 400;
}

.cat-arrow {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #F4F4F5;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s;
}

.cat-card:active .cat-arrow {
  background: #2563FF;
  color: #fff;
}

.cat-arrow svg {
  width: 14px;
  height: 14px;
  color: #333;
}

.cat-card:active .cat-arrow svg {
  color: #fff;
}

/* Catalog footer link */
.catalog-more {
  margin-top: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 16px;
  border: 1px solid #E8E8E8;
  border-radius: 14px;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  text-decoration: none;
  transition: background 0.2s;
  background: #fff;
}

.catalog-more:active {
  background: #F4F4F5;
}

/* ===== ADVANTAGES ===== */
.adv-section {
  background: var(--white);
}

.adv-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
}

.adv-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 20px 16px;
  transition: all 0.3s;
}

.adv-card:active {
  transform: translateY(-2px);
  border-color: var(--blue);
}

.adv-icon {
  width: 44px;
  height: 44px;
  background: var(--blue-light);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  border: 1px solid rgba(26, 86, 219, 0.1);
}

.adv-icon svg {
  width: 20px;
  height: 20px;
}

.adv-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 12px;
  font-weight: 700;
  margin-bottom: 8px;
  line-height: 1.3;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.adv-text {
  font-size: 12px;
  color: #666;
  line-height: 1.6;
}

/* ===== GUARANTEE ===== */
.guarantee-section {
  background: var(--white);
}

.guarantee-card {
  background: linear-gradient(135deg, #FFF8F5, #FFF2EC);
  border: 1px solid #FFCFB8;
  border-radius: 12px;
  padding: 20px 16px;
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.g-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #FF7A45, #FF5520);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.g-icon svg {
  width: 24px;
  height: 24px;
}

.g-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 4px;
}

.g-sub {
  font-size: 12px;
  color: #888;
  line-height: 1.5;
}

/* ===== COMPARISON ===== */
.comparison-section {
  background: var(--bg);
}

.comp-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}

.comp-card {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--white);
  transition: all 0.3s;
}

.comp-card:active {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
}

.comp-visual {
  height: 160px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.comp-card.dtf .comp-visual {
  background: linear-gradient(145deg, #1A56DB, #3B70EE);
}

.comp-card.emb .comp-visual {
  background: linear-gradient(145deg, #1a2a1a, #2a4a2a);
}

.comp-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  font-family: 'Unbounded', sans-serif;
  font-size: 9px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 16px;
  letter-spacing: 0.08em;
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.comp-body {
  padding: 20px 16px;
}

.comp-title {
  font-family: 'Unbounded', sans-serif;
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 8px;
}

.comp-text {
  font-size: 12px;
  color: #555;
  line-height: 1.6;
  margin-bottom: 12px;
}

.comp-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.comp-tag {
  font-size: 11px;
  font-weight: 500;
  padding: 4px 12px;
  border-radius: 16px;
  background: var(--bg);
  border: 1px solid var(--border);
}

/* ===== CASES ===== */
.cases-section {
  background: var(--black);
}

.cases-section h2,
.cases-section .sec-label {
  color: #fff;
}

.cases-section .sec-sub {
  color: rgba(255, 255, 255, 0.4);
}

.cases-mosaic {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  margin-bottom: 24px;
}

.case-tile {
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: flex-end;
  cursor: pointer;
  min-height: 180px;
}

.ct1 { background: linear-gradient(145deg, #0D1B4B, #1A56DB); }
.ct2 { background: linear-gradient(145deg, #0D2B0D, #1A6B1A); }
.ct3 { background: linear-gradient(145deg, #1B0D4B, #5B1ADB); }
.ct4 { background: linear-gradient(145deg, #2B0D0D, #8B1A1A); }

.case-tile-info {
  position: relative;
  z-index: 2;
  padding: 16px;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.65) 0%, transparent 100%);
  width: 100%;
}

.case-tile-label {
  font-family: 'Unbounded', sans-serif;
  font-size: 10px;
  font-weight: 700;
